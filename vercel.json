{
  "version": 2,
  "installCommand": "npm install --prefix apps/web && npm install --prefix apps/api && cd apps/api && npx prisma generate",
  "buildCommand": "cd apps/web && npm run build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "apps/api/src/**,apps/api/prisma/schema.prisma,apps/api/package.json",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}

# ─── Servidor ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Banco de Dados ─────────────────────────────────────────
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:sua_senha@localhost:5432/dashboard_adm"

# ─── JWT ────────────────────────────────────────────────────
# Gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=troque_por_segredo_longo_aleatorio_access
JWT_REFRESH_SECRET=troque_por_segredo_longo_aleatorio_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cookies ────────────────────────────────────────────────
COOKIE_SECRET=troque_por_segredo_cookie

# ─── CORS ───────────────────────────────────────────────────
# Origem do frontend (sem barra no final)
CORS_ORIGIN=http://localhost:3000

# ─── Google Sheets ──────────────────────────────────────────
# Caminho para o JSON da Service Account do Google Cloud
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# Ou cole o JSON como string (para deploy em nuvem):
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
